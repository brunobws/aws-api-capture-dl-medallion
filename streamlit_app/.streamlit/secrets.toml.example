# Streamlit Secrets Configuration (Template)
#
# Este arquivo é APENAS um template de exemplo.
# Para usar secrets no Streamlit, siga as instruções:
#
# Local Development:
#   1. Crie a pasta: ~/.streamlit/secrets.toml
#   2. Coloque suas credenciais lá (não na pasta do projeto!)
#
# Cloud Deployment (Streamlit Cloud):
#   1. Vá para: app.streamlit.io > Secrets
#   2. Cole o conteúdo abaixo
#
# IMPORTANTE: NUNCA commite credenciais no Git!
#

# AWS Credentials (use variáveis de ambiente ou IAM roles em vez disso)
[aws]
region = "sa-east-1"
# NÃO ADICIONE access_key_id e secret_access_key aqui!
# Use as credenciais do seu ~/.aws/credentials em vez disso

# Athena Configuration
[athena]
database = "gold"
s3_output_location = "s3://bws-dl-logs-sae1-prd/athena/query_results/"

# Application Settings
[app]
theme = "light"
layout = "wide"
rows_to_display = 1000
